# Локальная разработка
DJANGO_SECRET_KEY=dev-only-not-for-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# YandexGPT
# Установите один из ключей: YANDEX_API_KEY или YANDEX_IAM_TOKEN
# YANDEX_GPT_MODEL настраивается при необходимости, по умолчанию gpt://b1gtun08c2i8n7n9qmlf/yandexgpt-lite
# YANDEX_API_URL можно переопределить, если используется другой API endpoint
# По умолчанию используется: https://llm.api.cloud.yandex.net/foundationModels/v1/completion
YANDEX_API_KEY=your-api-key-here
# YANDEX_IAM_TOKEN=
# YANDEX_GPT_MODEL=gpt://b1gtun08c2i8n7n9qmlf/yandexgpt-lite
# YANDEX_API_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/completion

# Production (DJANGO_DEBUG=False) — см. .env.production.example
