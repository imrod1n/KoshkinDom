# Локальная разработка
DJANGO_SECRET_KEY=dev-only-not-for-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# YandexGPT
# Установите один из ключей: YANDEX_API_KEY или YANDEX_IAM_TOKEN
# YANDEX_GPT_MODEL настраивается при необходимости, по умолчанию yandex-gpt-3.5
# YANDEX_GPT_ENDPOINT можно переопределить, если используется другая версия API.
# Пример правильного endpoint:
# https://api.generative.cloud.yandex.net/v1/models/yandex-gpt-3.5/completions
YANDEX_API_KEY=AQVN3l-vqx-BxxJbiTkCds1V5-SusM-jFDOxyr1C
# YANDEX_IAM_TOKEN=
# YANDEX_GPT_MODEL=yandex-gpt-3.5
YANDEX_GPT_ENDPOINT=https://api.generative.cloud.yandex.net/v1/models/yandex-gpt-3.5/completions

# Production (DJANGO_DEBUG=False) — см. .env.production.example
