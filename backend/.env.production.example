# Production — только для сервера и проверки: python manage.py check --deploy
# Локально: set -a && source .env.production && python manage.py check --deploy

DJANGO_SECRET_KEY=REPLACE_WITH_GENERATED_KEY
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.ru,www.yourdomain.ru
CORS_ORIGINS=https://yourdomain.ru
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
